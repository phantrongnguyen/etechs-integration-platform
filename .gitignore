# ------------------------------------------------------------------------------
# 1. Security & Secrets
# ------------------------------------------------------------------------------

.env
.env.*
!.env.example
*.pem
*.key
*.pub
*.cert
*.crt
*.pfx
secrets/
credentials/
*credentials*.json
*token*.json
jwt/
configs/*private*
configs/*secret*

# ------------------------------------------------------------------------------
# 2. Môi trường Python & Django (Backend - middleware-be)
# ------------------------------------------------------------------------------
# Thư mục môi trường ảo
venv/
.venv/
env/
.env/
ENV/
bin/
lib/
include/

# Thư mục cache và compiled code
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Database SQLite cục bộ dùng test nhanh
*.sqlite3
db.sqlite3

